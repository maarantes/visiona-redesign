---
import Root from "@/components/Root.astro";
import { Banner } from "@/components/Banner";
import { sanityClient } from "@/sanity/client";
import { BANNER_CAROUSEL_QUERY, type BannerCarousel } from "@/sanity/schemas/Home/BannerCarousel/data";

const slides: BannerCarousel[] = await sanityClient.fetch(BANNER_CAROUSEL_QUERY, {}, { perspective: "published" });
---

<Root title="Home">
  <Banner slides={slides} client:load />
  <div class="bg-slate-950 h-400" />
</Root>
