---
import { footerColumns } from "@/data/footer";
import facebook from "@/assets/images/social-facebook.svg";
import linkedin from "@/assets/images/social-linkedin.svg";
import translate from "@/assets/images/translate.svg";
import partners from "@/assets/images/partners.svg";
import { Icon } from "@/components/Icon";
import LogoText from "./LogoText.astro";
---

<footer class="bg-[#00030F] text-white">
  <div class="section-container py-8 lg:py-16">
    <div
      class="grid grid-cols-2 sm:grid-cols-3 lg:flex lg:flex-wrap lg:justify-between gap-x-8 gap-y-10"
    >
      {
        footerColumns.map((col) => (
          <div class="flex flex-col gap-3">
            <h3 class="font-medium text-white tracking-wide">{col.heading}</h3>
            <ul class="flex flex-col gap-2">
              {col.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-[15px] text-slate-400 hover:text-white"
                  >
                    {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>

    <div class="mt-20">
      <div class="flex flex-col lg:flex-row justify-between gap-6">
        <div class="flex flex-col sm:flex-row sm:items-center gap-8 sm:gap-4">
          <div class="flex gap-4 shrink-0">
            <a href="#" aria-label="Facebook">
              <img src={facebook.src} alt="Facebook" class="size-6" />
            </a>
            <a href="#" aria-label="LinkedIn">
              <img src={linkedin.src} alt="LinkedIn" class="size-6" />
            </a>
          </div>

          <div class="max-sm:hidden w-px h-8 bg-white/20"></div>

          <button
            type="button"
            class="flex items-center gap-2 text-slate-400 hover:text-white cursor-pointer"
          >
            <img src={translate.src} alt="" class="size-6" />
            Português (PT)
            <Icon name="chevron-down" strokeWidth={1.5} />
          </button>

          <div class="max-sm:hidden w-px h-8 bg-white/20"></div>

          <img
            src={partners.src}
            alt="Parceiros Embrapii e Finep"
            class="h-8 self-start"
          />
        </div>

        <p class="text-slate-400">
          Visiona Tecnologia Espacial S.A. <span id="footer-year"></span> © Todos
          os direitos reservados.
        </p>
      </div>

      <LogoText />
    </div>
  </div>
</footer>

<script>
  const el = document.getElementById("footer-year");
  if (el) el.textContent = new Date().getFullYear().toString();
</script>
