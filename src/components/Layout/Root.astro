---
import "@/styles/global.css";
import { Navbar } from "@/components/Navbar";
import SEO from "./SEO.astro";
import Footer from "@/components/Footer/index.astro";
import { sanityFetch } from "@/sanity/client";
import {
  NAVBAR_CONFIG_QUERY,
  type NavbarImages,
} from "@/sanity/schemas/Shared/Navbar/data";

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const navbarImages = await sanityFetch<NavbarImages>(NAVBAR_CONFIG_QUERY);
const submenuImages = Object.fromEntries(
  Object.entries(navbarImages ?? {})
    .filter(([, v]) => v != null)
    .map(([key, url]) => [key, `${url}?auto=format&fit=max&w=800&q=75`]),
) as Record<string, string>;
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=1" />
    <SEO title={title} description={description} />
    {
      Object.values(submenuImages).map((url) => (
        <link rel="preload" as="image" href={url} fetchpriority="low" />
      ))
    }
  </head>

  <body class="font-sans antialiased">
    <Navbar client:load submenuImages={submenuImages} />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
