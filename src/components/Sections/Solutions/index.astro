---
import Section from "@/components/Layout/Section/index.astro";
import { sanityFetch } from "@/sanity/client";
import {
  SOLUTION_CARDS_QUERY,
  type SolutionCard,
} from "@/sanity/schemas/Home/SolutionCards/data";
import SolutionCards from "./SolutionCards.astro";

const cards = await sanityFetch<SolutionCard[]>(
  SOLUTION_CARDS_QUERY,
  {},
  { perspective: "published" },
);
---

<Section noPbMobile>
  <h2 class="section-title">
    <span class="text-primary">Inovação tecnológica</span> aplicada para mudar negócios
  </h2>
  <p class="section-subtitle">Conheça nossas principais soluções:</p>
  <SolutionCards cards={cards} />
</Section>
